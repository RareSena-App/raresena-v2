# RareSena Rebuild App v2.0 — Environment Variables
# Copy this file to .env and fill in all values
# Add every variable to Vercel Environment Variables before deploying
# NEVER commit .env to GitHub
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── SUPABASE ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...YOUR_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...YOUR_SERVICE_ROLE_KEY

# ── STRIPE — REBUILD PREMIUM ──────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_REBUILD_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_REBUILD_ANNUAL_PRICE_ID=price_...

# ── STRIPE — CREATOR MEMBERSHIP ───────────────────────────────────
VITE_STRIPE_CREATOR_ONETIME_PRICE_ID=price_...
VITE_STRIPE_CREATOR_MONTHLY_PRICE_ID=price_...

# ── STRIPE — WEBHOOK ──────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_...

# ── APP ──────────────────────────────────────────────────────────
VITE_APP_URL=https://app.raresena.com
